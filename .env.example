# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000

# ─── Supabase ────────────────────────────────────────────────────────────────
# Obtain from: Supabase Dashboard → Project → Settings → API
# Use the service role key (not the anon key) — it bypasses RLS.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Frontend ────────────────────────────────────────────────────────────────
# Full public URL of the deployed frontend (used for CORS allow-list)
FRONTEND_URL=

# ─── Meta WhatsApp Cloud API ─────────────────────────────────────────────────
# Obtain from: https://developers.facebook.com/apps → WhatsApp → API Setup

# Permanent system user token with whatsapp_business_messaging permission
META_ACCESS_TOKEN=

# Phone Number ID shown in Meta Developer Portal → WhatsApp → API Setup
PHONE_NUMBER_ID=

# WhatsApp Business Account ID
WABA_ID=

# Secret token you choose when registering the webhook in the Meta Portal.
# Must match the value you enter in Meta → WhatsApp → Webhooks → Verify Token.
VERIFY_TOKEN=

# App Secret from Meta → App Settings → Basic (used for X-Hub-Signature-256 verification)
META_APP_SECRET=

# ─── Academy contact ─────────────────────────────────────────────────────────
# E.164 format — the academy's own WhatsApp number for outbound notifications
ACADEMY_WHATSAPP_NUMBER=

# ─── AI Agent (future) ───────────────────────────────────────────────────────
AI_API_KEY=
